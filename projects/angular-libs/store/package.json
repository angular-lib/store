    "access": "public"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "keywords": [
    "angular",
    "signals",
    "state-management",
    "entity-adapter",
    "resource-api",
    "history",
    "undo",
    "redo",
    "storage",
    "localstorage",
    "state",
    "store",
    "oop",
    "cross-tab",
    "cross-tab-sync",
    "sync",
    "ngrx-alternative",
    "ngrx-signalstore-alternative",
    "rxjs-free"
